{
  "name": "Dev Tools",
  "description": "Encode, decode, hash and convert text — base64, url, hex, jwt, hashes, uuid, epoch, json, slug, case",
  "icon": "data_object",
  "frecency": "plugin",
  "handler": {
    "type": "stdio",
    "command": "python3 handler.py"
  },
  "match": {
    "patterns": [
      "^(base64|b64|unbase64|b64d|url|urld|hex|unhex|md5|sha1|sha256|sha512|jwt|rot13|upper|lower|reverse|len|json|jsonmin|slug|camel|pascal|snake|kebab|const|title)\\s+\\S",
      "^(uuid|epoch|now)(\\s|$)"
    ],
    "priority": 90
  },
  "supportedPlatforms": [
    "niri",
    "hyprland"
  ]
}
